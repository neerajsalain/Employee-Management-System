<%- include('partials/header') %>
<section class="card">
  <div class="card-heading">
    <h1>Employee Records</h1>
    <a class="button button-primary" href="/employees/new">New Employee</a>
  </div>
  <% if (!employees.length) { %>
  <p>No employee records are available yet.</p>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Department</th>
        <th>Position</th>
        <th>Salary</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% employees.forEach(function(employee) { %>
      <tr>
        <td><%= employee.name %></td>
        <td><%= employee.email %></td>
        <td><%= employee.department %></td>
        <td><%= employee.position %></td>
        <td>$<%= Number(employee.salary).toFixed(2) %></td>
        <td class="actions-cell">
          <a class="button button-secondary small" href="/employees/<%= employee.id %>/edit">Edit</a>
          <form method="POST" action="/employees/<%= employee.id %>/delete" class="inline-form">
            <button class="button button-danger small" type="submit">Delete</button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</section>
<%- include('partials/footer') %>
