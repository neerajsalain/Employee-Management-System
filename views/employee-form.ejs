<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= buttonText %> - Employee Management System</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="page-header">
      <h1><%= buttonText %></h1>
      <nav>
        <a href="/dashboard">Dashboard</a>
        <a href="/employees">Employees</a>
        <a href="/logout">Logout</a>
      </nav>
    </header>

    <section class="panel">
      <% if (errors && errors.length) { %>
      <div class="alert alert-error">
        <ul>
          <% errors.forEach((error) => { %>
          <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form action="<%= action %>" method="POST" class="auth-form">
        <label>
          Name
          <input type="text" name="name" value="<%= employee.name || "" %>" required />
        </label>
        <label>
          Email
          <input type="email" name="email" value="<%= employee.email || "" %>" required />
        </label>
        <label>
          Department
          <input type="text" name="department" value="<%= employee.department || "" %>" required />
        </label>
        <label>
          Position
          <input type="text" name="position" value="<%= employee.position || "" %>" required />
        </label>
        <label>
          Salary
          <input type="number" step="0.01" name="salary" value="<%= employee.salary || "" %>" required />
        </label>
        <button type="submit" class="button button-primary"><%= buttonText %></button>
      </form>
    </section>
  </body>
</html>
