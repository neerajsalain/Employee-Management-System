<%- include('partials/header') %>
<section class="card">
  <h1>Dashboard</h1>
  <p>Welcome back, <strong><%= user.name %></strong>.</p>
  <div class="dashboard-grid">
    <div class="dashboard-card">
      <h2>Account</h2>
      <p><strong>Email:</strong> <%= user.email %></p>
      <p><strong>Role:</strong> <%= user.role %></p>
    </div>
    <% if (user.role === 'admin') { %>
    <div class="dashboard-card">
      <h2>Employee Management</h2>
      <p>Administrators can create, update, and delete employee records.</p>
      <a class="button button-secondary" href="/employees">Manage Employees</a>
    </div>
    <% } else { %>
    <div class="dashboard-card">
      <h2>Protected Data</h2>
      <p>Your account is protected and you may access your profile and dashboard content securely.</p>
    </div>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
