<%- include('partials/header') %>
<section class="card">
  <h1>Dashboard</h1>
  <p>Welcome back, <strong><%= userDetails.name %></strong>.</p>
  <div class="dashboard-grid">
    <div class="dashboard-card">
      <h2>Account Summary</h2>
      <p><strong>Email:</strong> <%= userDetails.email %></p>
      <p><strong>Role:</strong> <%= userDetails.role %></p>
      <p><strong>Member since:</strong> <%= new Date(userDetails.created_at).toLocaleDateString() %></p>
      <a class="button button-secondary" href="/profile">View Profile</a>
    </div>

    <% if (userDetails.role === 'admin') { %>
    <div class="dashboard-card">
      <h2>Employee Insights</h2>
      <p><strong>Total employees:</strong> <%= employeeCount %></p>
      <p>Quick access for admin management and new hire review.</p>
      <a class="button button-secondary" href="/employees">Manage Employees</a>
    </div>
    <% } else { %>
    <div class="dashboard-card">
      <h2>Your Account</h2>
      <p>Use your profile page to view your details and stay up-to-date with company access.</p>
      <a class="button button-secondary" href="/profile">Open Profile</a>
    </div>
    <% } %>
  </div>

  <% if (userDetails.role === 'admin' && recentEmployees && recentEmployees.length) { %>
  <div class="card section-card">
    <h2>Latest hires</h2>
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Department</th>
          <th>Position</th>
          <th>Hired</th>
        </tr>
      </thead>
      <tbody>
        <% recentEmployees.forEach((employee) => { %>
        <tr>
          <td><%= employee.name %></td>
          <td><%= employee.department %></td>
          <td><%= employee.position %></td>
          <td><%= new Date(employee.hired_at).toLocaleDateString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <div class="card section-card">
    <h2>Quick Links</h2>
    <div class="dashboard-actions">
      <a class="button button-primary" href="/profile">Profile</a>
      <% if (userDetails.role === 'admin') { %>
      <a class="button button-primary" href="/employees">Employees</a>
      <% } %>
      <a class="button button-secondary" href="/logout">Logout</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
